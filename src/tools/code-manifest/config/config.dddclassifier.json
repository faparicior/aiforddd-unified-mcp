{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "app_details": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "language": {
            "type": "string",
            "enum": [
              "kotlin",
              "java"
            ]
          },
          "mode": {
            "type": "string"
          },
          "alias": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "code",
              "test"
            ]
          }
        },
        "required": [
          "path",
          "language",
          "mode",
          "alias",
          "type"
        ]
      }
    },
    "destination_folder": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "app_details",
    "destination_folder"
  ]
}
